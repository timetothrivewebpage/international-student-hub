source "https://rubygems.org"

# Jekyll 4 — built and deployed via GitHub Actions (see .github/workflows/deploy.yml).
gem "jekyll", "~> 4.3"

# Windows / JRuby timezone data (harmless elsewhere).
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]

# Required on Ruby 3+ (no longer bundled as a default gem).
gem "webrick", "~> 1.8"
gem "csv"
gem "base64"
gem "bigdecimal"
